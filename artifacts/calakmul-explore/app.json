{
  "expo": {
    "name": "Calakmul Explore",
    "slug": "calakmul-explore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "calakmul-explore",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f2418"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.calakmulexplore.app"
    },
    "android": {
      "package": "com.calakmulexplore.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f2418"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f0557467-9685-4cf1-98c8-c50519c200f9"
      }
    }
  }
}
